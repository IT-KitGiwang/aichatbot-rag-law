# ===========================================
# AI CHATBOT RAG - ENVIRONMENT VARIABLES
# ===========================================
# Copy file này thành .env và điền API keys

# Google Gemini API Key
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API Key (tùy chọn, nếu dùng GPT)
OPENAI_API_KEY=your_openai_api_key_here

# PostgreSQL Database
POSTGRES_USER=chatbot_user
POSTGRES_PASSWORD=chatbot_pass_2026
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=chatbot_rag
DATABASE_URL=postgresql+asyncpg://chatbot_user:chatbot_pass_2026@postgres:5432/chatbot_rag

# ChromaDB
CHROMA_PERSIST_DIR=./vectorstore
CHROMA_COLLECTION_NAME=legal_documents

# Embedding Model
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIMENSION=1024

# Reranker Model
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# LLM Settings
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# Retrieval Settings
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
RELEVANCE_THRESHOLD=0.3

# Redis (Cache & Session)
REDIS_URL=redis://redis:6379/0

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# LangSmith Monitoring (tùy chọn)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=chatbot-rag-legal
